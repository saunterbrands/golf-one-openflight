# Waveshare 12.3-inch panel on Raspberry Pi 5 DSI1 is exposed by DRM as DSI-2.
# Transform 90 is the installed 180-degree display orientation.
wlr-randr --output DSI-2 --transform 90

# Launch Golf One after the Wayland desktop is ready. The launcher selects real
# radar mode only when it positively identifies the OPS243-A.
sh -lc 'cd /home/openflight/golf-one-openflight && exec ./scripts/launch-golf-one.sh >> /home/openflight/golf-one-kiosk.log 2>&1' &
