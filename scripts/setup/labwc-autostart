# Waveshare 12.3-inch panel on Raspberry Pi 5 DSI1 is exposed by DRM as DSI-2.
# Transform 90 is the installed 180-degree display orientation.
wlr-randr --output DSI-2 --transform 90

# Launch Golf One after the Wayland desktop is ready. Mock mode keeps the
# software usable until production launch-monitor hardware is connected.
sh -lc 'if ! pgrep -f "/home/openflight/golf-one-openflight/.venv/bin/openflight-server" >/dev/null; then cd /home/openflight/golf-one-openflight && exec ./scripts/launch-golf-one.sh --mock --sim >> /home/openflight/golf-one-kiosk.log 2>&1; fi' &
